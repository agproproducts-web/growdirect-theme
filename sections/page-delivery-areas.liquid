<style>
  /* ── GrowDirect — Delivery Areas ── */
    :root {
      --green:#0A4A2F; --accent:#F28C38; --accent-hover:#E07B2D;
      --text:#1A3C34; --text-secondary:#5C6B66; --text-muted:#8A9A94;
      --border:#E8F0EB; --bg:#F8F9FA; --white:#fff;
      --radius:1rem; --radius-xl:1.5rem;
      --font-heading:"Plus Jakarta Sans",-apple-system,sans-serif;
      --font-body:"Inter",-apple-system,sans-serif;
    }
    *,::before,::after { box-sizing:border-box; margin:0; padding:0; }
    body { font-family:var(--font-body); color:var(--text); background:var(--bg); -webkit-font-smoothing:antialiased; }
    .container { max-width:880px; margin:0 auto; padding:0 1.5rem; }

    .breadcrumb-bar { background:#fff; border-bottom:1px solid var(--border); }
    .breadcrumb-bar .container { max-width:1100px; }
    .breadcrumb { padding:.6rem 0; font-size:.78rem; color:var(--text-muted); font-family:var(--font-heading); }
    .breadcrumb a { color:var(--text-muted); text-decoration:none; }
    .breadcrumb a:hover { color:var(--text); }
    .breadcrumb span { margin:0 .4rem; }

    .page-layout { padding:1.75rem 0 5rem; }
    .section-card { background:#fff; border:1px solid var(--border); border-radius:var(--radius-xl); overflow:hidden; margin-bottom:1.25rem; }
    .section-body { padding:2rem 1.75rem; }

    .page-eyebrow { font-size:.68rem; font-weight:700; letter-spacing:.12em; text-transform:uppercase; color:var(--accent); margin-bottom:.4rem; font-family:var(--font-heading); display:inline-flex; align-items:center; gap:.4rem; }
    .page-title { font-family:var(--font-heading); font-size:1.85rem; font-weight:800; color:var(--text); line-height:1.1; margin-bottom:.6rem; }
    .page-intro { font-size:1rem; color:var(--text-secondary); line-height:1.7; margin-bottom:1.25rem; }
    .eyebrow-dot { width:5px; height:5px; background:var(--accent); border-radius:50%; animation:pulse 2s ease-in-out infinite; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.4} }

    .prose p { font-size:.95rem; color:var(--text-secondary); line-height:1.75; margin-bottom:1rem; }
    .prose p:last-child { margin-bottom:0; }
    .prose strong { color:var(--text); font-weight:700; }

    /* DELIVERY HIGHLIGHT */
    .delivery-highlight { display:flex; align-items:center; gap:.8rem; padding:.875rem 1.125rem; background:rgba(10,74,47,.05); border:1px solid rgba(10,74,47,.12); border-radius:var(--radius); margin:1.25rem 0; font-size:.875rem; color:var(--green); font-weight:600; font-family:var(--font-heading); }
    .delivery-highlight svg { flex-shrink:0; }

    /* SUBURB GROUP */
    .suburb-section-title { font-family:var(--font-heading); font-size:1.05rem; font-weight:800; color:var(--text); margin:1.75rem 0 .25rem; }
    .suburb-section-meta { font-size:.78rem; color:var(--text-muted); font-family:var(--font-heading); font-weight:600; margin-bottom:1rem; }
    .suburb-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(140px,1fr)); gap:.5rem; }
    .suburb { padding:.625rem .9rem; background:var(--bg); border:1px solid var(--border); border-radius:var(--radius); font-family:var(--font-heading); font-size:.82rem; font-weight:600; color:var(--text); text-align:center; }

    .support-image { width:100%; border-radius:var(--radius); display:block; margin:1.5rem 0 0; }

    .page-layout-single { padding:1.75rem 0 5rem; }
    .page-note { font-size:.9rem; color:var(--text-muted); line-height:1.65; font-style:italic; margin-top:.5rem; }
    .section-body h2 { font-family:var(--font-heading); font-size:1.15rem; font-weight:800; color:var(--text); margin:1.5rem 0 .6rem; }
    .section-body h2:first-child { margin-top:0; }
    .section-body p { font-size:.95rem; color:var(--text-secondary); line-height:1.75; margin-bottom:1rem; }
    .section-body p:last-child { margin-bottom:0; }
    .section-body ul, .section-body ol { padding-left:1.25rem; margin-bottom:1rem; color:var(--text-secondary); line-height:1.75; font-size:.95rem; }
    .section-body li { margin-bottom:.5rem; }
    .section-body li:last-child { margin-bottom:0; }
    .section-body strong { color:var(--text); font-weight:700; }
  </style>

  <div class="breadcrumb-bar">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a><span>›</span>
        <span style="color:var(--text);font-weight:600;">Delivery Areas</span>
      </div>
    </div>
  </div>

<div class="container">
