      var match = allSuburbs.find(function(s) {
        return s.name.toLowerCase() === val || s.name.toLowerCase().startsWith(val);
      });
      if (match) {
        result.textContent = '✓ ' + match.name + ' is in our ' + match.zone + ' delivery zone.';
