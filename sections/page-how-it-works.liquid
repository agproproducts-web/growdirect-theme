            <div class="faq-icon">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </div>
          </div>
          <div class="faq-a">Yes. After choosing a Saver Box, you can top up with additional items to suit your household.</div>
        </div>

      </div>
    </div>
  </div>
</section>

<!-- Section 7 — Closing CTA -->
<section class="cta-strip">
  <div class="container">
    <h2>Built for a simpler <em>weekly shop</em></h2>
    <p>GrowDirect combines practical value, flexible ordering, and direct-to-door delivery to make everyday food shopping easier for Melbourne households.</p>
    <div class="btn-row">
      <a class="btn btn-primary" href="/collections/saver-boxes" style="padding:1rem 2rem;">Shop Saver Boxes</a>
      <a class="btn btn-secondary" href="/collections/weekly-specials" style="padding:1rem 2rem;">View Weekly Specials</a>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.faq-q').forEach(function(q) {
    q.addEventListener('click', function() {
      var item = q.parentElement;
      var isOpen = item.classList.contains('open');
      document.querySelectorAll('.faq-item').forEach(function(i) { i.classList.remove('open'); });
      if (!isOpen) item.classList.add('open');
    });
  });
</script>

