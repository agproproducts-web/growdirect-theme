      sizes:[{label:'1kg',price:2.00},{label:'2kg',price:3.50},{label:'3kg',price:5.00},{label:'5kg',price:8.00}] },
    { id:'mm-carrots',   name:'Carrots',           subtitle:'Fresh everyday',             category:'vegetables', mm_sort_order:3, default_size_index:1,
      sizes:[{label:'1kg',price:2.50},{label:'2kg',price:4.50},{label:'3kg',price:6.00},{label:'5kg',price:9.00}] },
    { id:'mm-sweetpot',  name:'Sweet Potato',      subtitle:'Versatile staple',           category:'vegetables', mm_sort_order:4, default_size_index:0,
      sizes:[{label:'1kg',price:3.00},{label:'2kg',price:5.50},{label:'3kg',price:8.00}] },
    { id:'mm-rice',      name:'Basmati Rice',      subtitle:'Long grain · Pantry staple', category:'pantry',     mm_sort_order:1, default_size_index:1,
      sizes:[{label:'1kg',price:2.00},{label:'2kg',price:3.80},{label:'5kg',price:9.00}] },
    { id:'mm-flour',     name:'Plain Flour',       subtitle:'All-purpose baking',         category:'pantry',     mm_sort_order:2, default_size_index:1,
      sizes:[{label:'1kg',price:1.60},{label:'2kg',price:3.00},{label:'5kg',price:7.00}] },
    { id:'mm-sugar',     name:'White Sugar',       subtitle:'Everyday pantry',            category:'pantry',     mm_sort_order:3, default_size_index:1,
      sizes:[{label:'1kg',price:1.80},{label:'2kg',price:3.20},{label:'5kg',price:7.50}] },
    { id:'mm-pasta',     name:'Pasta',             subtitle:'Spaghetti or penne',         category:'pantry',     mm_sort_order:4, default_size_index:1,
      sizes:[{label:'500g',price:1.80},{label:'1kg',price:3.20},{label:'2kg',price:5.50}] },
  ];

  // ============================================================
  // STATE
  // ============================================================
  const specialsState = {};
  const mmState = {};
  let mmActiveCategory = 'fruit';
  let specialsSort = 'featured';
  let wasUnlocked = false;

  function getFruitState(id) {
    if (!specialsState[id]) { const p=specialsProducts.find(x=>x.id===id); specialsState[id]={sizeIdx:p.defaultSizeIdx,qty:0}; }
    return specialsState[id];
  }
  function getMmState(id) {
    if (!mmState[id]) { const p=mmProducts.find(x=>x.id===id); mmState[id]={sizeIdx:p.default_size_index,qty:0}; }
    return mmState[id];
  }

  function anyFruitSelected() {
    return Object.values(specialsState).some(s => s.qty > 0);
  }

  function getGrandTotal() {
    const sp = Object.entries(specialsState).reduce((s,[id,st])=>{ if(!st.qty)return s; const p=specialsProducts.find(x=>x.id===id); return s+p.sizes[st.sizeIdx].price*st.qty; },0);
    const mm = Object.entries(mmState).reduce((s,[id,st])=>{ if(!st.qty)return s; const p=mmProducts.find(x=>x.id===id); return s+p.sizes[st.sizeIdx].price*st.qty; },0);
    const qty = Object.values(specialsState).reduce((s,c)=>s+c.qty,0)+Object.values(mmState).reduce((s,c)=>s+c.qty,0);
    return { total:sp+mm, qty };
  }

  // ============================================================
  // MM VISIBILITY — pure reactive, no one-way flag
  // ============================================================
  function syncMmVisibility() {
    const unlocked = anyFruitSelected();
    const section  = document.getElementById('mm-section');
    const prompt   = document.getElementById('mm-locked-prompt');
    if (unlocked) {
      if (prompt)  prompt.classList.add('hidden');
      if (section) section.classList.add('unlocked');
      if (!wasUnlocked && section) section.scrollIntoView({ behavior:'smooth', block:'start' });
    } else {
      if (prompt)  prompt.classList.remove('hidden');
      if (section) section.classList.remove('unlocked');
      // Clear all MM quantities so no ghost state survives a re-lock
      Object.keys(mmState).forEach(id => { mmState[id].qty = 0; });
      renderMixMatchList();
      renderSummary();
    }
    wasUnlocked = unlocked;
  }

  // ============================================================
  // RENDER SUMMARY
  // ============================================================
  function renderSummary() {
    const fruitListEl = document.querySelector('[data-fruit-list]');
    const mmListEl       = document.querySelector('[data-mm-list]');
    const totalEl        = document.querySelector('[data-total]');
    const deliveryEl     = document.getElementById('delivery-note');
    const ctaBtn         = document.querySelector('[data-add-to-cart]');
    const cartBtn        = document.getElementById('cart-btn');
    const { total, qty } = getGrandTotal();

    if (cartBtn) cartBtn.textContent = qty > 0 ? `Cart ${qty}` : 'Cart 0';

    // Specials rows
    if (fruitListEl) {
      const added = Object.entries(specialsState).filter(([,s])=>s.qty>0);
      fruitListEl.innerHTML = added.length
        ? added.map(([id,s])=>{ const p=specialsProducts.find(x=>x.id===id); const sz=p.sizes[s.sizeIdx];
            return `<div class="summary-row"><span>${p.name} <strong>${sz.label}</strong> × ${s.qty}</span><span>+${fmt(sz.price*s.qty)}</span></div>`; }).join('')
        : '<p class="summary-empty">No specials added yet.</p>';
    }

    // MM rows
    if (mmListEl) {
      const added = Object.entries(mmState).filter(([,s])=>s.qty>0);
      mmListEl.innerHTML = added.length
        ? added.map(([id,s])=>{ const p=mmProducts.find(x=>x.id===id); const sz=p.sizes[s.sizeIdx];
            return `<div class="summary-row"><span>${p.name} <strong>${sz.label}</strong> × ${s.qty}</span><span>+${fmt(sz.price*s.qty)}</span></div>`; }).join('')
        : '<p class="summary-empty">No extras added yet.</p>';
    }

    // Total
    if (totalEl) totalEl.textContent = fmt(total);

    // Delivery
    if (deliveryEl) {
      if (total >= DELIVERY_THRESHOLD) {
        deliveryEl.textContent = '\u2713 You\'ve unlocked free delivery';
        deliveryEl.className = 'delivery-note unlocked';
      } else {
        const rem = (DELIVERY_THRESHOLD - total).toFixed(2);
        deliveryEl.textContent = total > 0 ? `Add $${rem} more to unlock free delivery` : `Add $${DELIVERY_THRESHOLD.toFixed(2)} more to unlock free delivery`;
        deliveryEl.className = 'delivery-note locked';
      }
    }

    if (ctaBtn) ctaBtn.disabled = qty === 0;
  }

  // ============================================================
  // RENDER SPECIALS GRID
  // ============================================================
  const BADGE_LABELS = { sale:'Sale', new:'New in', limited:'Limited' };

  function getSortedFruitProducts() {
    const list = [...specialsProducts];
    if (specialsSort==='price_asc')  return list.sort((a,b)=>a.sizes[a.defaultSizeIdx].price-b.sizes[b.defaultSizeIdx].price);
    if (specialsSort==='price_desc') return list.sort((a,b)=>b.sizes[b.defaultSizeIdx].price-a.sizes[a.defaultSizeIdx].price);
    if (specialsSort==='savings')    return list.sort((a,b)=>{
      const sA=a.sizes[a.defaultSizeIdx].was?a.sizes[a.defaultSizeIdx].was-a.sizes[a.defaultSizeIdx].price:0;
      const sB=b.sizes[b.defaultSizeIdx].was?b.sizes[b.defaultSizeIdx].was-b.sizes[b.defaultSizeIdx].price:0;
      return sB-sA;
    });
    return list.sort((a,b)=>a.sortOrder-b.sortOrder);
  }

  function renderSpecialsGrid() {
    const grid    = document.getElementById('specials-grid');
    const countEl = document.getElementById('specials-count');
    if (!grid) return;
    const list = getSortedFruitProducts();
    if (countEl) countEl.textContent = list.length + ' products';
    grid.innerHTML = '';

    list.forEach(product => {
      const s    = getFruitState(product.id);
      const size = product.sizes[s.sizeIdx];
      const card = document.createElement('div');
      card.className = 'product-card' + (s.qty>0?' in-cart':'');

      const pillsHtml = product.sizes.map((sz,i) =>
        `<button type="button" class="size-pill${i===s.sizeIdx?' selected':''}" data-size-idx="${i}">${sz.label}</button>`
      ).join('');
      const badgeHtml = product.badge ? `<span class="special-badge ${product.badge}">${BADGE_LABELS[product.badge]}</span>` : '';
      const pricingHtml = size.was
        ? `<div class="card-pricing"><span class="card-price">${fmt(size.price)}</span><span class="card-was">${fmt(size.was)}</span><span class="card-save">Save ${fmt(size.was-size.price)}</span></div>`
        : `<div class="card-pricing"><span class="card-price">${fmt(size.price)}</span></div>`;

      card.innerHTML = `
        <div class="card-img">${badgeHtml}
          <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke="#0A4A2F" stroke-width=".75" stroke-linecap="round">
            <circle cx="12" cy="12" r="9"/><path d="M12 3c0 0 3 4 3 9s-3 9-3 9"/><path d="M3 12h18"/>
          </svg>
        </div>
        <div class="card-body">
          <div><div class="card-name">${product.name}</div><div class="card-subtitle">${product.subtitle}</div></div>
          <div class="size-pills">${pillsHtml}</div>
          ${pricingHtml}
          <div class="card-actions">
            <div class="qty-ctrl">
              <button type="button" class="qty-btn" data-minus ${s.qty<=0?'disabled':''}>−</button>
              <span class="qty-val">${s.qty}</span>
              <button type="button" class="qty-btn" data-plus>+</button>
            </div>
            <button type="button" class="add-btn${s.qty>0?' added':''}" data-add>${s.qty>0?'\u2713 Added':'Add to cart'}</button>
          </div>
        </div>`;

      card.querySelectorAll('.size-pill').forEach(pill => {
        pill.addEventListener('click', ()=>{ s.sizeIdx=parseInt(pill.dataset.sizeIdx); s.qty=0; rerenderAll(); });
      });
      card.querySelector('[data-minus]').addEventListener('click', ()=>{ if(s.qty<=0)return; s.qty--; rerenderAll(); });
      card.querySelector('[data-plus]').addEventListener('click',  ()=>{ s.qty++; rerenderAll(); });
      card.querySelector('[data-add]').addEventListener('click',   ()=>{ if(s.qty===0)s.qty=1; rerenderAll(); });
      grid.appendChild(card);
    });
  }

  // ============================================================
  // RENDER MIX & MATCH — same pattern as Saver Box page
  // ============================================================
  function renderMixMatchList() {
    const listEl  = document.querySelector('[data-mixmatch-list]');
    const emptyEl = document.querySelector('[data-mixmatch-empty]');
    if (!listEl) return;

    const filtered = mmProducts
      .filter(p => p.category === mmActiveCategory)
      .sort((a,b) => a.mm_sort_order - b.mm_sort_order);

    if (emptyEl) emptyEl.hidden = filtered.length > 0;
    listEl.innerHTML = '';

    filtered.forEach(product => {
      const s    = getMmState(product.id);
      const size = product.sizes[s.sizeIdx];
      const row  = document.createElement('div');
      row.className = 'mixmatch-item' + (s.qty>0?' has-qty':'');

      const pillsHtml = product.sizes.map((sz,i) =>
        `<button type="button" class="size-pill${i===s.sizeIdx?' selected':''}" data-size-idx="${i}">${sz.label}</button>`
      ).join('');

      row.innerHTML = `
        <div class="mm-thumb-placeholder">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#0A4A2F" stroke-width="1" stroke-linecap="round">
            <circle cx="12" cy="12" r="9"/><path d="M12 3c0 0 3 4 3 9s-3 9-3 9"/><path d="M3 12h18"/>
          </svg>
        </div>
        <div class="mm-item-inner">
          <div class="mm-row-top">
            <div class="mm-item-info">
              <div class="mixmatch-item__title">${product.name}</div>
              <div class="mixmatch-item__meta">${product.subtitle}</div>
            </div>
            <div class="mixmatch-item__price">${fmt(size.price)}</div>
          </div>
          <div class="mm-row-bottom">
            <div class="size-pills">${pillsHtml}</div>
            <div class="mixmatch-qty-control">
              <button type="button" class="mixmatch-qty-btn" data-mm-minus ${s.qty<=0?'disabled':''}>−</button>
              <span class="mixmatch-qty-value">${s.qty}</span>
              <button type="button" class="mixmatch-qty-btn" data-mm-plus>+</button>
            </div>
          </div>
        </div>`;

      row.querySelectorAll('.size-pill').forEach(pill => {
        pill.addEventListener('click', ()=>{ s.sizeIdx=parseInt(pill.dataset.sizeIdx); s.qty=0; rerenderAll(); });
      });
      row.querySelector('[data-mm-minus]').addEventListener('click', ()=>{ if(s.qty<=0)return; s.qty--; rerenderAll(); });
      row.querySelector('[data-mm-plus]').addEventListener('click',  ()=>{ s.qty++; rerenderAll(); });

      listEl.appendChild(row);
    });
  }

  // MM TABS
  document.querySelectorAll('[data-mixmatch-tab]').forEach(tab => {
    tab.addEventListener('click', () => {
      mmActiveCategory = tab.dataset.mixmatchTab;
      document.querySelectorAll('[data-mixmatch-tab]').forEach(t => {
        const active = t===tab;
        t.classList.toggle('is-active', active);
        t.setAttribute('aria-selected', String(active));
        t.setAttribute('tabindex', active?'0':'-1');
      });
      renderMixMatchList();
    });
    tab.addEventListener('keydown', e => {
      if(e.key!=='ArrowRight'&&e.key!=='ArrowLeft') return;
      const arr=Array.from(document.querySelectorAll('[data-mixmatch-tab]'));
      const next=arr[(arr.indexOf(tab)+(e.key==='ArrowRight'?1:-1)+arr.length)%arr.length];
      next.focus(); next.click();
    });
  });

  // ============================================================
  // MASTER RERENDER
  // ============================================================
  function rerenderAll() {
    renderSpecialsGrid();
    renderMixMatchList();
    renderSummary();
    syncMmVisibility();
  }

  // CTA
  document.querySelector('[data-add-to-cart]').addEventListener('click', () => {
    const spItems = Object.entries(specialsState).filter(([,s])=>s.qty>0)
      .map(([id,s])=>{ const p=specialsProducts.find(x=>x.id===id); const sz=p.sizes[s.sizeIdx]; return {name:p.name,size:sz.label,qty:s.qty,price:sz.price}; });
    const mmItems = Object.entries(mmState).filter(([,s])=>s.qty>0)
      .map(([id,s])=>{ const p=mmProducts.find(x=>x.id===id); const sz=p.sizes[s.sizeIdx]; return {name:p.name,size:sz.label,qty:s.qty,price:sz.price}; });
    const all = [...spItems, ...mmItems];
    const { total } = getGrandTotal();
    console.log('Add selected items to cart:', all, 'Total:', fmt(total));
    // Shopify: fetch('/cart/add.js', { method:'POST', body: JSON.stringify({ items: all.map(i=>({id:i.variantId,quantity:i.qty})) }) })
    alert('\u2713 Would add to cart:\n\n' + all.map(i=>`${i.name} ${i.size} \u00d7${i.qty} — ${fmt(i.price*i.qty)}`).join('\n') + '\n\nTotal: ' + fmt(total));
  });

  // SORT
  document.getElementById('sort-select').addEventListener('change', function(){ specialsSort=this.value; renderSpecialsGrid(); });

  // INIT
  rerenderAll();
  </script>

