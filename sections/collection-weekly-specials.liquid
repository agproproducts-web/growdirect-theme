<style>
  /* ── GrowDirect — Weekly Specials ── */
  /* ── DESIGN TOKENS — identical to Saver Box page ── */
    :root {
      --green:#0A4A2F; --accent:#F28C38; --accent-hover:#E07B2D;
      --text:#1A3C34; --text-secondary:#5C6B66; --text-muted:#8A9A94;
      --border:#E8F0EB; --bg:#F8F9FA; --white:#fff;
      --radius:1rem; --radius-xl:1.5rem;
      --font-heading:"Plus Jakarta Sans",-apple-system,sans-serif;
      --font-body:"Inter",-apple-system,sans-serif;
    }
    *,::before,::after { box-sizing:border-box; margin:0; padding:0; }
    body { font-family:var(--font-body); color:var(--text); background:var(--bg); -webkit-font-smoothing:antialiased; }
    .container { max-width:1100px; margin:0 auto; padding:0 1.5rem; }

    /* HEADER */
    .site-header { background:var(--green); padding:.875rem 1.5rem; }
    .header-inner { display:flex; align-items:center; justify-content:space-between; max-width:1100px; margin:0 auto; }
    .logo { font-family:var(--font-heading); font-size:1.4rem; font-weight:800; color:#fff; text-decoration:none; }
    .logo span { color:var(--accent); }
    nav a { color:rgba(255,255,255,.75); margin-right:1.5rem; font-weight:500; font-size:.875rem; text-decoration:none; font-family:var(--font-heading); }
    nav a:hover { color:#fff; }
    .btn-cart { display:inline-flex; align-items:center; padding:.6rem 1.125rem; background:var(--accent); color:#fff; border-radius:999px; font-family:var(--font-heading); font-weight:700; font-size:.875rem; text-decoration:none; }

    /* BREADCRUMB */
    .breadcrumb-bar { background:#fff; border-bottom:1px solid var(--border); }
    .breadcrumb { padding:.6rem 0; font-size:.78rem; color:var(--text-muted); font-family:var(--font-heading); }
    .breadcrumb a { color:var(--text-muted); text-decoration:none; }
    .breadcrumb a:hover { color:var(--text); }
    .breadcrumb span { margin:0 .4rem; }

    /* ── PAGE LAYOUT — same as Saver Box ── */
    .page-layout { display:grid; grid-template-columns:1fr 340px; gap:1.75rem; padding:1.75rem 0 5rem; align-items:start; }

    /* ── SECTION CARDS — same as Saver Box ── */
    .section-card { background:#fff; border:1px solid var(--border); border-radius:var(--radius-xl); overflow:hidden; margin-bottom:1.25rem; }
    .section-header { padding:1.125rem 1.5rem; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; }
    .section-title { font-family:var(--font-heading); font-size:.95rem; font-weight:800; color:var(--text); }
    .section-step { font-size:.72rem; color:var(--text-muted); font-family:var(--font-heading); font-weight:600; }
    .section-body { padding:1.5rem; }

    /* HERO — compact, inside first section card */
    .page-eyebrow { font-size:.68rem; font-weight:700; letter-spacing:.12em; text-transform:uppercase; color:var(--accent); margin-bottom:.35rem; font-family:var(--font-heading); }
    .page-title { font-family:var(--font-heading); font-size:1.5rem; font-weight:800; color:var(--text); line-height:1.1; margin-bottom:.4rem; }
    .page-intro { font-size:.875rem; color:var(--text-secondary); line-height:1.65; margin-bottom:.5rem; }
    .page-note { font-size:.75rem; color:var(--text-muted); font-style:italic; }
    .page-refresh { display:inline-flex; align-items:center; gap:.35rem; margin-top:.5rem; font-size:.72rem; color:var(--text-muted); font-family:var(--font-heading); font-weight:600; }
    .eyebrow-dot { width:5px; height:5px; background:var(--accent); border-radius:50%; animation:pulse 2s ease-in-out infinite; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.4} }

    /* TOOLBAR */
    .toolbar-bar { display:flex; align-items:center; justify-content:space-between; padding:.75rem 0; border-bottom:1px solid var(--border); margin-bottom:1.25rem; flex-wrap:wrap; gap:.5rem; }
    .specials-count { font-size:.78rem; color:var(--text-muted); font-family:var(--font-heading); font-weight:600; }
    .sort-select { padding:.35rem .8rem; border:1.5px solid var(--border); border-radius:999px; font-family:var(--font-body); font-size:.78rem; color:var(--text); background:#fff; outline:none; cursor:pointer; }

    /* FRUIT PRODUCT GRID */
    .specials-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:1rem; }

    /* PRODUCT CARD — same radius/border system as Saver Box */
    .product-card { border:1px solid var(--border); border-radius:var(--radius); overflow:hidden; display:flex; flex-direction:column; background:#fff; transition:border-color .2s; }
    .product-card:hover { border-color:#c8dcc8; }
    .product-card.in-cart { border-color:var(--green); background:rgba(10,74,47,.015); }
    .card-img { background:var(--bg); aspect-ratio:1; display:flex; align-items:center; justify-content:center; border-bottom:1px solid var(--border); position:relative; }
    .card-img svg { opacity:.12; }
    .special-badge { position:absolute; top:.6rem; left:.6rem; padding:.2rem .55rem; border-radius:999px; font-family:var(--font-heading); font-size:.62rem; font-weight:700; }
    .special-badge.sale    { background:#DC2626; color:#fff; }
    .special-badge.new     { background:var(--green); color:#fff; }
    .special-badge.limited { background:var(--accent); color:#fff; }
    .card-body { padding:.875rem 1rem; flex:1; display:flex; flex-direction:column; gap:.5rem; }
    .card-name { font-family:var(--font-heading); font-size:.875rem; font-weight:800; color:var(--text); }
    .card-subtitle { font-size:.72rem; color:var(--text-muted); margin-top:-.15rem; }
    .card-pricing { display:flex; align-items:baseline; gap:.4rem; flex-wrap:wrap; }
    .card-price { font-family:var(--font-heading); font-size:1rem; font-weight:800; color:var(--accent); }
    .card-was { font-size:.75rem; color:var(--text-muted); text-decoration:line-through; }
    .card-save { font-size:.62rem; font-weight:700; color:#16A34A; background:rgba(22,163,74,.08); padding:.15rem .45rem; border-radius:999px; font-family:var(--font-heading); }
    .size-pills { display:flex; gap:.3rem; flex-wrap:wrap; }
    .size-pill { padding:.22rem .6rem; border:1.5px solid var(--border); border-radius:999px; font-family:var(--font-heading); font-size:.68rem; font-weight:700; color:var(--text-secondary); background:#fff; cursor:pointer; transition:all .15s; white-space:nowrap; }
    .size-pill:hover { border-color:var(--green); color:var(--green); }
    .size-pill.selected { background:var(--green); border-color:var(--green); color:#fff; }
    .card-actions { display:flex; align-items:center; gap:.5rem; margin-top:auto; }
    .qty-ctrl { display:flex; align-items:center; border:1.5px solid var(--border); border-radius:999px; overflow:hidden; transition:border-color .2s; }
    .product-card.in-cart .qty-ctrl { border-color:var(--green); }
    .qty-btn { width:28px; height:28px; display:flex; align-items:center; justify-content:center; background:transparent; border:none; font-family:var(--font-heading); font-size:.95rem; font-weight:700; color:var(--text); cursor:pointer; transition:background .15s; }
    .qty-btn:hover:not(:disabled) { background:rgba(10,74,47,.06); }
    .qty-btn:disabled { opacity:.3; cursor:not-allowed; }
    .qty-val { min-width:24px; text-align:center; font-family:var(--font-heading); font-size:.82rem; font-weight:700; }
    .add-btn { flex:1; padding:.45rem .65rem; background:var(--accent); color:#fff; border:none; border-radius:999px; font-family:var(--font-heading); font-weight:700; font-size:.75rem; cursor:pointer; transition:background .2s; }
    .add-btn:hover { background:var(--accent-hover); }
    .add-btn.added { background:var(--green); }

    /* ── MM SECTION — hidden until first fruit item selected ── */
    #mm-section { display:none; }
    #mm-section.unlocked { display:block; }
    #mm-locked-prompt { display:block; }
    #mm-locked-prompt.hidden { display:none; }

    /* MM reveal note */
    .mm-reveal-note { font-size:.82rem; color:var(--green); font-weight:600; font-family:var(--font-heading); padding:.65rem .875rem; background:rgba(10,74,47,.05); border:1px solid rgba(10,74,47,.12); border-radius:.875rem; margin-bottom:1.125rem; }

    /* MM TABS — same as Saver Box page */
    .mixmatch-tabs { display:flex; gap:.35rem; border-bottom:1px solid var(--border); margin-bottom:1.25rem; }
    .mixmatch-tab { padding:.5rem 1.1rem; font-family:var(--font-heading); font-size:.82rem; font-weight:700; color:var(--text-muted); background:transparent; border:none; border-bottom:2.5px solid transparent; cursor:pointer; margin-bottom:-1px; transition:all .2s; white-space:nowrap; }
    .mixmatch-tab:hover { color:var(--text); }
    .mixmatch-tab.is-active { color:var(--green); border-bottom-color:var(--green); }

    /* MM PRODUCT ROWS */
    .mixmatch-item { background:var(--bg); border:1px solid var(--border); border-radius:var(--radius); padding:.75rem 1rem; margin-bottom:.625rem; transition:border-color .2s; display:flex; align-items:center; gap:.875rem; }
    .mixmatch-item:last-child { margin-bottom:0; }
    .mixmatch-item.has-qty { border-color:var(--green); background:rgba(10,74,47,.02); }
    .mm-thumb { width:64px; height:64px; min-width:64px; border-radius:.5rem; background:var(--bg); border:1px solid var(--border); object-fit:cover; display:block; }
    .mm-thumb-placeholder { width:64px; height:64px; min-width:64px; border-radius:.5rem; background:#F0F7F2; border:1px solid var(--border); display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .mm-thumb-placeholder svg { opacity:.18; }
    .mm-item-inner { flex:1; min-width:0; display:flex; flex-direction:column; gap:.5rem; }
    .mm-row-top { display:flex; align-items:flex-start; justify-content:space-between; gap:.75rem; }
    .mm-item-info { flex:1; min-width:0; }
    .mixmatch-item__title { font-family:var(--font-heading); font-size:.875rem; font-weight:700; color:var(--text); }
    .mixmatch-item__meta { font-size:.72rem; color:var(--text-muted); margin-top:.15rem; }
    .mixmatch-item__price { font-family:var(--font-heading); font-size:1rem; font-weight:800; color:var(--accent); white-space:nowrap; flex-shrink:0; }
    .mm-row-bottom { display:flex; align-items:center; justify-content:space-between; gap:.5rem; flex-wrap:wrap; }
    .mixmatch-qty-control { display:flex; align-items:center; border:1.5px solid var(--border); border-radius:999px; overflow:hidden; transition:border-color .2s; }
    .mixmatch-item.has-qty .mixmatch-qty-control { border-color:var(--green); }
    .mixmatch-qty-btn { width:30px; height:30px; display:flex; align-items:center; justify-content:center; background:transparent; border:none; font-family:var(--font-heading); font-size:1rem; font-weight:700; color:var(--text); cursor:pointer; transition:background .15s; }
    .mixmatch-qty-btn:hover:not(:disabled) { background:rgba(10,74,47,.06); }
    .mixmatch-qty-btn:disabled { opacity:.3; cursor:not-allowed; }
    .mixmatch-qty-value { min-width:26px; text-align:center; font-family:var(--font-heading); font-size:.875rem; font-weight:700; }

    /* ── ORDER SUMMARY — identical to Saver Box page ── */
    .summary-card { background:#fff; border:1px solid var(--border); border-radius:var(--radius-xl); overflow:hidden; position:sticky; top:80px; }
    .summary-header { background:var(--green); padding:1.125rem 1.5rem; }
    .summary-header h3 { font-family:var(--font-heading); font-size:.95rem; font-weight:800; color:#fff; margin-bottom:.1rem; }
    .summary-header p { font-size:.72rem; color:rgba(255,255,255,.55); }
    .summary-body { padding:1.25rem 1.5rem; }
    .summary-group-label { font-family:var(--font-heading); font-size:.65rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:var(--text-muted); margin-top:.875rem; margin-bottom:.4rem; }
    .summary-group-label:first-child { margin-top:0; }
    .summary-row { display:flex; align-items:flex-start; justify-content:space-between; gap:.5rem; padding:.35rem 0; border-bottom:1px solid var(--border); font-size:.8rem; }
    .summary-row:last-child { border-bottom:none; }
    .summary-row span:first-child { color:var(--text); flex:1; line-height:1.4; }
    .summary-row span:last-child { font-family:var(--font-heading); font-weight:700; color:var(--accent); white-space:nowrap; }
    .summary-empty { font-size:.78rem; color:var(--text-muted); font-style:italic; padding:.25rem 0; }
    .summary-footer { padding:1rem 1.5rem 1.5rem; border-top:1px solid var(--border); }
    .summary-total-row { display:flex; align-items:center; justify-content:space-between; margin-bottom:.625rem; }
    .summary-total-label { font-family:var(--font-heading); font-size:.78rem; font-weight:700; color:var(--text-muted); text-transform:uppercase; letter-spacing:.06em; }
    [data-total] { font-family:var(--font-heading); font-size:1.6rem; font-weight:800; color:var(--text); }
    .delivery-note { font-size:.72rem; text-align:center; margin-bottom:1rem; line-height:1.5; }
    .delivery-note.locked   { color:var(--text-muted); }
    .delivery-note.unlocked { color:#16A34A; font-weight:600; }
    [data-add-to-cart] { width:100%; padding:.9rem; background:var(--accent); color:#fff; border:none; border-radius:999px; font-family:var(--font-heading); font-weight:700; font-size:.9rem; cursor:pointer; transition:background .2s; }
    [data-add-to-cart]:hover { background:var(--accent-hover); }
    [data-add-to-cart]:disabled { opacity:.45; cursor:not-allowed; }
    .summary-note { font-size:.72rem; color:var(--text-muted); text-align:center; margin-top:.625rem; line-height:1.5; }

    /* FOOTER */
    .site-footer { background:#061F13; padding:1.75rem 0 1.25rem; }
    .footer-inner { max-width:1100px; margin:0 auto; padding:0 1.5rem; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:1rem; }
    .footer-copy { font-size:.75rem; color:rgba(255,255,255,.35); }
    .footer-links a { color:rgba(255,255,255,.45); font-size:.78rem; text-decoration:none; margin-left:1.25rem; }
    .footer-links a:hover { color:#fff; }

    @media(max-width:900px) { .page-layout { grid-template-columns:1fr; } .summary-card { position:static; } }
    @media(max-width:560px) { .specials-grid { grid-template-columns:1fr 1fr; } }
  </style>

  /* Hero image */
  .collection-hero { width:100%; aspect-ratio:21/6; overflow:hidden; background:var(--green); }
  .collection-hero .hero-img { width:100%; height:100%; object-fit:cover; display:block; }
</style>

