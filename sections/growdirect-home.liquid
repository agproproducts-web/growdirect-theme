        <a href="#specials" style="color:#F28C38;font-weight:700;margin-right:2rem;font-size:.9rem;">Weekly Specials ✦</a>
        <a href="#mix" style="color:rgba(255,255,255,.75);margin-right:2rem;font-weight:500;font-size:.9rem;">Mix &amp; Match</a>
        <a href="#delivery" style="color:rgba(255,255,255,.75);font-weight:500;font-size:.9rem;">Delivery</a>
      </nav>
      <a class="btn btn-primary" href="#" style="padding:.75rem 1.25rem;border-radius:999px;font-size:.875rem;">Cart 0</a>
