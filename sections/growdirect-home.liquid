        <div style="background:#F4F8F5;border:1px solid #E2EDE5;border-radius:1.25rem;padding:2rem 1.75rem;transition:all .3s;">
          <div style="font-size:3rem;font-weight:800;color:rgba(10,74,47,.1);line-height:1;margin-bottom:1.25rem;font-family:var(--font-heading);">03</div>
