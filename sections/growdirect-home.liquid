  <script>
    /* FAQ accordions */
    document.querySelectorAll('.faq3-q').forEach(q => {
      q.addEventListener('click', () => {
        const item = q.parentElement;
        const isOpen = item.classList.contains('open');
        document.querySelectorAll('.faq3-item').forEach(i => i.classList.remove('open'));
        if (!isOpen) item.classList.add('open');
      });
    });
    document.querySelectorAll('.faq2-question').forEach(q => {
      q.addEventListener('click', () => {
        const item = q.parentElement;
        const isOpen = item.classList.contains('open');
        document.querySelectorAll('.faq2-item').forEach(i => i.classList.remove('open'));
        if (!isOpen) item.classList.add('open');
      });
    });
    document.querySelectorAll('.option').forEach(opt => {
      opt.addEventListener('click', () => {
        document.querySelectorAll('.option').forEach(o => o.classList.remove('active'));
        opt.classList.add('active');
      });
    });

    /* Hamburger menu toggle */
    const hamburger = document.querySelector('.hamburger');
    const nav = document.querySelector('.site-header nav');
    if (hamburger && nav) {
      hamburger.addEventListener('click', () => {
        hamburger.classList.toggle('active');
        nav.classList.toggle('open');
      });
      nav.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          hamburger.classList.remove('active');
          nav.classList.remove('open');
        });
      });
    }

    /* Delivery zones — body-level popups with JS positioning */
    document.addEventListener('DOMContentLoaded', function() {
      var activePopup = null;

      /* Move all zone popups to body so position:fixed works reliably */
      document.querySelectorAll('.zone-popup').forEach(function(p) {
        document.body.appendChild(p);
      });

      function positionPopup(popup, zone) {
        var r = zone.getBoundingClientRect();
        var pw = popup.offsetWidth || 580;
        var ph = popup.offsetHeight || 200;
        var vw = window.innerWidth;
        var vh = window.innerHeight;
        var m = 12;

        var top = r.top - ph - 12;
        if (top < m) top = r.bottom + 12;
        if (top + ph > vh - m) top = vh - ph - m;

        var left = r.left + r.width / 2 - pw / 2;
        left = Math.max(m, Math.min(left, vw - pw - m));

        popup.style.top = top + 'px';
        popup.style.left = left + 'px';
      }

      document.querySelectorAll('.zone').forEach(function(zone) {
        zone.addEventListener('mouseenter', function() {
          if (activePopup) activePopup.classList.remove('active');
          var popup = document.getElementById(zone.dataset.popup);
          if (!popup) return;
          activePopup = popup;
          popup.classList.add('active');
          requestAnimationFrame(function() { positionPopup(popup, zone); });
        });
        zone.addEventListener('mouseleave', function() {
          if (activePopup) activePopup.classList.remove('active');
          activePopup = null;
        });
      });

      window.addEventListener('scroll', function() {
        if (activePopup) {
          var zone = document.querySelector('.zone:hover');
          if (zone) positionPopup(activePopup, zone);
          else { activePopup.classList.remove('active'); activePopup = null; }
        }
      }, { passive: true });
    });
  </script>

</div>

