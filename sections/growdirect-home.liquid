  <script>
    /* FAQ accordions */
    document.querySelectorAll('.faq3-q').forEach(q => {
      q.addEventListener('click', () => {
        const item = q.parentElement;
        const isOpen = item.classList.contains('open');
        document.querySelectorAll('.faq3-item').forEach(i => i.classList.remove('open'));
        if (!isOpen) item.classList.add('open');
      });
    });
    document.querySelectorAll('.faq2-question').forEach(q => {
      q.addEventListener('click', () => {
        const item = q.parentElement;
        const isOpen = item.classList.contains('open');
        document.querySelectorAll('.faq2-item').forEach(i => i.classList.remove('open'));
        if (!isOpen) item.classList.add('open');
      });
    });
    document.querySelectorAll('.option').forEach(opt => {
      opt.addEventListener('click', () => {
        document.querySelectorAll('.option').forEach(o => o.classList.remove('active'));
        opt.classList.add('active');
      });
    });

    /* #16 Hamburger menu toggle */
    const hamburger = document.querySelector('.hamburger');
    const nav = document.querySelector('.site-header nav');
    if (hamburger && nav) {
      hamburger.addEventListener('click', () => {
        hamburger.classList.toggle('active');
        nav.classList.toggle('open');
      });
      /* Close menu when a nav link is tapped */
      nav.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          hamburger.classList.remove('active');
          nav.classList.remove('open');
        });
      });
    }

    /* Delivery zone popups — fixed-position auto-adjust system */
    (function() {
      const GAP = 10;       /* space between zone chip and popup */
      const EDGE = 12;      /* min distance from viewport edge */
      let activePopup = null;

      function closeAll() {
        document.querySelectorAll('.zone-popup.visible').forEach(p => {
          p.classList.remove('visible');
        });
        activePopup = null;
      }

      function positionPopup(wrap, popup) {
        const arrow = popup.querySelector('.zone-popup-arrow');
        const zoneRect = wrap.getBoundingClientRect();
        const vw = window.innerWidth;
        const vh = window.innerHeight;

        /* Temporarily show to measure popup size */
        popup.style.visibility = 'hidden';
        popup.classList.add('visible');
        const pw = popup.offsetWidth;
        const ph = popup.offsetHeight;

        /* Decide: above or below the zone chip */
        const spaceAbove = zoneRect.top;
        const spaceBelow = vh - zoneRect.bottom;
        const placeBelow = spaceAbove < (ph + GAP + EDGE) && spaceBelow > spaceAbove;

        let top;
        if (placeBelow) {
          top = zoneRect.bottom + GAP;
          arrow.className = 'zone-popup-arrow arrow-top';
        } else {
          top = zoneRect.top - ph - GAP;
          arrow.className = 'zone-popup-arrow arrow-bottom';
        }

        /* Clamp vertically so popup doesn't go off screen */
        if (top < EDGE) top = EDGE;
        if (top + ph > vh - EDGE) top = vh - EDGE - ph;

        /* Horizontal: center on zone chip, then clamp to viewport */
        const zoneCenterX = zoneRect.left + zoneRect.width / 2;
        let left = zoneCenterX - pw / 2;

        if (left < EDGE) left = EDGE;
        if (left + pw > vw - EDGE) left = vw - EDGE - pw;

        /* Position arrow relative to popup so it points at the zone chip */
        const arrowX = zoneCenterX - left;
        const clampedArrowX = Math.max(16, Math.min(arrowX, pw - 16));
        arrow.style.left = clampedArrowX + 'px';

        popup.style.top = Math.round(top) + 'px';
        popup.style.left = Math.round(left) + 'px';
        popup.style.visibility = '';
      }

      document.querySelectorAll('.zone-wrap').forEach(wrap => {
        const zone = wrap.querySelector('.zone');
        const popup = wrap.querySelector('.zone-popup');
        if (!zone || !popup) return;

        /* Desktop: hover */
        wrap.addEventListener('mouseenter', () => {
          closeAll();
          positionPopup(wrap, popup);
          activePopup = popup;
        });
        wrap.addEventListener('mouseleave', () => {
          popup.classList.remove('visible');
          if (activePopup === popup) activePopup = null;
        });

        /* Mobile: tap to toggle */
        zone.addEventListener('click', (e) => {
          e.stopPropagation();
          if (activePopup === popup) {
            closeAll();
          } else {
            closeAll();
            positionPopup(wrap, popup);
            activePopup = popup;
          }
        });
      });

      /* Tap outside closes popup */
      document.addEventListener('click', (e) => {
        if (activePopup && !e.target.closest('.zone-popup') && !e.target.closest('.zone')) {
          closeAll();
        }
      });

      /* Reposition on scroll/resize while a popup is open */
      let ticking = false;
      function onViewChange() {
        if (!ticking && activePopup) {
          ticking = true;
          requestAnimationFrame(() => {
            if (activePopup) {
              const wrap = activePopup.closest('.zone-wrap');
              if (wrap) positionPopup(wrap, activePopup);
            }
            ticking = false;
          });
        }
      }
      window.addEventListener('scroll', onViewChange, { passive: true });
      window.addEventListener('resize', onViewChange, { passive: true });
    })();
  </script>

