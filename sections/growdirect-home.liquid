      alt=""
      aria-hidden="true"
      style="
        position:absolute;
        inset:0;
        width:100%;
        height:100%;
        object-fit:cover;
        object-position:center 40%;
        opacity:.28;
        pointer-events:none;
        z-index:0;
      "
    />
