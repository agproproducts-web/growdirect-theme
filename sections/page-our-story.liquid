        <h3>A modern business built on trusted foundations</h3>
        <p>GrowDirect brings traditional produce experience into a simpler, more convenient, direct-to-household food model.</p>
      </div>

    </div>
  </div>
</section>

<!-- Closing Trust Line -->
<section class="trust-line">
  <div class="container">
    <h2>Fresh produce knowledge built over generations,<br>now delivered for modern households.</h2>
  </div>
</section>

<!-- CTA Strip -->
