          <span class="box-card-cta">See what's inside →</span>
        </div>
      </a>

    </div>
  </div>

{% schema %}
{
  "name": "Saver Boxes Collection",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    }
  ]
}
{% endschema %}
