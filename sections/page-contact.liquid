<style>
  /* ── GrowDirect — Contact Us ── */
    :root {
      --green:#0A4A2F; --accent:#F28C38; --accent-hover:#E07B2D;
      --text:#1A3C34; --text-secondary:#5C6B66; --text-muted:#8A9A94;
      --border:#E8F0EB; --bg:#F8F9FA; --white:#fff;
      --radius:1rem; --radius-xl:1.5rem;
      --font-heading:"Plus Jakarta Sans",-apple-system,sans-serif;
      --font-body:"Inter",-apple-system,sans-serif;
    }
    *,::before,::after { box-sizing:border-box; margin:0; padding:0; }
    body { font-family:var(--font-body); color:var(--text); background:var(--bg); -webkit-font-smoothing:antialiased; }
    .container { max-width:680px; margin:0 auto; padding:0 1.5rem; }

    .breadcrumb-bar { background:#fff; border-bottom:1px solid var(--border); }
    .breadcrumb-bar .container { max-width:1100px; }
    .breadcrumb { padding:.6rem 0; font-size:.78rem; color:var(--text-muted); font-family:var(--font-heading); }
    .breadcrumb a { color:var(--text-muted); text-decoration:none; }
    .breadcrumb a:hover { color:var(--text); }
    .breadcrumb span { margin:0 .4rem; }

    .page-layout { padding:1.75rem 0 5rem; }
    .section-card { background:#fff; border:1px solid var(--border); border-radius:var(--radius-xl); overflow:hidden; margin-bottom:1.25rem; }
    .section-body { padding:2rem 1.75rem; }

    .page-eyebrow { font-size:.68rem; font-weight:700; letter-spacing:.12em; text-transform:uppercase; color:var(--accent); margin-bottom:.4rem; font-family:var(--font-heading); display:inline-flex; align-items:center; gap:.4rem; }
    .page-title { font-family:var(--font-heading); font-size:1.85rem; font-weight:800; color:var(--text); line-height:1.1; margin-bottom:.6rem; }
    .page-intro { font-size:1rem; color:var(--text-secondary); line-height:1.7; margin-bottom:1.5rem; }
    .eyebrow-dot { width:5px; height:5px; background:var(--accent); border-radius:50%; animation:pulse 2s ease-in-out infinite; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.4} }

    /* CONTACT FORM */
    .contact-form { display:flex; flex-direction:column; gap:1rem; }
    .field { display:flex; flex-direction:column; gap:.4rem; }
    .field label { font-family:var(--font-heading); font-size:.78rem; font-weight:700; color:var(--text); }
    .field input,
    .field textarea { width:100%; padding:.75rem 1rem; border:1.5px solid var(--border); border-radius:var(--radius); font-family:var(--font-body); font-size:.9rem; color:var(--text); background:#fff; outline:none; transition:border-color .15s; }
    .field input:focus,
    .field textarea:focus { border-color:var(--green); }
    .field textarea { resize:vertical; min-height:120px; line-height:1.5; }
    .submit-btn { padding:.85rem 1.5rem; background:var(--green); color:#fff; border:none; border-radius:999px; font-family:var(--font-heading); font-size:.9rem; font-weight:700; cursor:pointer; transition:background .2s; align-self:flex-start; }
    .submit-btn:hover { background:#0d5b3a; }

    .form-note { font-size:.78rem; color:var(--text-muted); font-family:var(--font-heading); font-weight:600; margin-top:1rem; display:flex; align-items:center; gap:.4rem; }
    .form-success { padding:.875rem 1.125rem; background:rgba(22,163,74,.08); border:1px solid rgba(22,163,74,.25); border-radius:var(--radius); font-size:.9rem; color:#16A34A; font-weight:600; font-family:var(--font-heading); margin-bottom:1.25rem; }
    .form-error { padding:.75rem 1rem; background:rgba(220,38,38,.06); border:1px solid rgba(220,38,38,.2); border-radius:var(--radius); font-size:.85rem; color:#DC2626; font-family:var(--font-heading); margin-bottom:1rem; }
    .form-error ul { list-style:none; padding:0; margin:0; }

    .support-image { width:100%; border-radius:var(--radius); display:block; margin:1.5rem 0 0; }

    .page-layout-single { padding:1.75rem 0 5rem; }
    .page-note { font-size:.9rem; color:var(--text-muted); line-height:1.65; font-style:italic; margin-top:.5rem; }
    .section-body h2 { font-family:var(--font-heading); font-size:1.15rem; font-weight:800; color:var(--text); margin:1.5rem 0 .6rem; }
    .section-body h2:first-child { margin-top:0; }
    .section-body p { font-size:.95rem; color:var(--text-secondary); line-height:1.75; margin-bottom:1rem; }
    .section-body p:last-child { margin-bottom:0; }
    .section-body ul, .section-body ol { padding-left:1.25rem; margin-bottom:1rem; color:var(--text-secondary); line-height:1.75; font-size:.95rem; }
    .section-body li { margin-bottom:.5rem; }
    .section-body li:last-child { margin-bottom:0; }
    .section-body strong { color:var(--text); font-weight:700; }
  </style>

  <div class="breadcrumb-bar">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a><span>›</span>
        <span style="color:var(--text);font-weight:600;">Contact Us</span>
      </div>
    </div>
  </div>

<div class="container">
  <div class="page-layout-single">
    <div class="section-card">
      <div class="section-body">
        <div class="page-eyebrow"><span class="eyebrow-dot"></span> Get In Touch</div>
        <h1 class="page-title">Contact</h1>
        <div class="page-intro">Get in touch with GrowDirect</div>
        <div class="page-note">If you have a question about ordering, delivery, Saver Boxes, or anything else, we are here to help. Use the contact form below and our team will get back to you as soon as possible.</div>
      </div>
    </div>

    <div class="section-card" style="margin-top:1.5rem;">
      <div class="section-body">
        <h2>Contact Details</h2>
        <p><strong>Email:</strong> hello@growdirect.com.au<br>
        <strong>Service Area:</strong> Melbourne metro<br>
        <strong>Response Time:</strong> As soon as possible</p>

        <h2>Send a Message</h2>
        {% form 'contact' %}
          <div style="margin-bottom:1rem;">
            <label for="ContactFormName" style="display:block;margin-bottom:.375rem;font-weight:600;">Full name</label>
            <input type="text" id="ContactFormName" name="contact[name]" autocomplete="name" style="width:100%;padding:.625rem .875rem;border:1px solid var(--border);border-radius:.5rem;font-size:1rem;">
          </div>
          <div style="margin-bottom:1rem;">
            <label for="ContactFormEmail" style="display:block;margin-bottom:.375rem;font-weight:600;">Email address</label>
            <input type="email" id="ContactFormEmail" name="contact[email]" autocomplete="email" style="width:100%;padding:.625rem .875rem;border:1px solid var(--border);border-radius:.5rem;font-size:1rem;">
          </div>
          <div style="margin-bottom:1rem;">
            <label for="ContactFormPhone" style="display:block;margin-bottom:.375rem;font-weight:600;">Phone number <span style="font-weight:400;color:var(--text-muted);">(optional)</span></label>
            <input type="tel" id="ContactFormPhone" name="contact[phone]" autocomplete="tel" style="width:100%;padding:.625rem .875rem;border:1px solid var(--border);border-radius:.5rem;font-size:1rem;">
          </div>
          <div style="margin-bottom:1rem;">
            <label for="ContactFormTopic" style="display:block;margin-bottom:.375rem;font-weight:600;">Enquiry type</label>
            <select id="ContactFormTopic" name="contact[topic]" style="width:100%;padding:.625rem .875rem;border:1px solid var(--border);border-radius:.5rem;font-size:1rem;background:white;">
              <option value="">Select a topic</option>
              <option value="existing-order">Existing order</option>
              <option value="delivery-question">Delivery question</option>
              <option value="product-question">Product question</option>
              <option value="saver-box">Saver Box enquiry</option>
              <option value="general">General enquiry</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div style="margin-bottom:1.5rem;">
            <label for="ContactFormMessage" style="display:block;margin-bottom:.375rem;font-weight:600;">Message</label>
            <textarea id="ContactFormMessage" name="contact[body]" rows="6" style="width:100%;padding:.625rem .875rem;border:1px solid var(--border);border-radius:.5rem;font-size:1rem;resize:vertical;"></textarea>
          </div>
          <button type="submit" style="background:var(--green);color:white;padding:.75rem 2rem;border:none;border-radius:2rem;font-size:1rem;font-weight:600;cursor:pointer;">Send message</button>
          <p style="margin-top:.75rem;font-size:.875rem;color:var(--text-muted);">We will get back to you as soon as possible.</p>
        {% endform %}

        <h2 style="margin-top:2rem;">Common Questions</h2>
        <p><strong>What should I contact GrowDirect about?</strong><br>You can contact GrowDirect for general enquiries, ordering support, delivery questions, or help after placing an order.</p>
        <p><strong>Where can I check delivery information first?</strong><br>Visit the Delivery Areas page to review suburb coverage before getting in touch.</p>
        <p><strong>How long does it take to get a response?</strong><br>GrowDirect will aim to respond as soon as possible to customer enquiries and support questions.</p>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Contact",
  "settings": [
    {
      "type": "image_picker",
      "id": "support_image",
      "label": "Support image"
    }
  ]
}
{% endschema %}
